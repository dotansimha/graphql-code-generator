  },
  "devDependencies": {
    "@graphql-codegen/cli": "workspace:*",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "cypress": "15.15.0",
    "start-server-and-test": "3.0.5",
    "typescript": "6.0.3"
  },
  "bob": false,
  "browserslist": {
